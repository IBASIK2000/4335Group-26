<Window x:Class="Group4335._4335_Maslennicov"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Об авторе" 
        Height="250" 
        Width="350"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <TextBlock Text="Информация об авторе" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"
                       Foreground="#2C3E50"/>
            
            <TextBlock Text="ФИО: Масленников Алексей Сергеевич" 
                       FontSize="14" 
                       Margin="5"
                       Foreground="#34495E"/>
            
            <TextBlock Text="Возраст: 18 лет" 
                       FontSize="14" 
                       Margin="5"
                       Foreground="#34495E"/>
            
            <TextBlock Text="Группа: 4335" 
                       FontSize="14" 
                       Margin="5"
                       Foreground="#34495E"/>
            
            <TextBlock Text="Номер в списке: 9" 
                       FontSize="14" 
                       Margin="5"
                       Foreground="#34495E"/>
            
            <Button Content="Закрыть" 
                    Width="100" 
                    Margin="0,20,0,0"
                    Padding="10,5"
                    Click="CloseButton_Click"
                    Background="#3498DB"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
